# GitHub Integration
# Get a token at: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_token_here

# OAuth App (for production)
# Create at: GitHub → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=your_oauth_client_id
GITHUB_CLIENT_SECRET=your_oauth_client_secret
GITHUB_REDIRECT_URI=https://your-api.com/auth/github/callback
